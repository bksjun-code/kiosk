{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/controls/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icon/**",
              "components/lists/**",
              "components/navigation/**",
              "components/overlays/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='SheetAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|destructive|key|ref|className|style|children)$/]",
        "message": "<SheetAction> doesn't accept that prop. Declared props: label, value, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|style|key|ref|className|style|children)$/]",
        "message": "<ActivityIndicator> doesn't accept that prop. Declared props: size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|cancel|destructive|key|ref|className|style|children)$/]",
        "message": "<AlertAction> doesn't accept that prop. Declared props: label, value, cancel, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, initials, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|dot|color|max|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: count, dot, color, max, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|tint|icon|iconTrailing|block|destructive|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, tint, icon, iconTrailing, block, destructive, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|tinted|gray|bordered|plain)$/]",
        "message": "<Button> variant must be one of 'filled' | 'tinted' | 'gray' | 'bordered' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:mini|small|medium|large)$/]",
        "message": "<Button> size must be one of 'mini' | 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|radius|elevated|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, radius, elevated, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|weight|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, weight, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:light|regular|semibold|bold)$/]",
        "message": "<Icon> weight must be one of 'light' | 'regular' | 'semibold' | 'bold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|tint|shape|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, tint, shape, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|glass|filled)$/]",
        "message": "<IconButton> variant must be one of 'plain' | 'glass' | 'filled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<IconButton> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|rounded)$/]",
        "message": "<IconButton> shape must be one of 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='List'] > JSXAttribute > JSXIdentifier[name!=/^(?:header|footer|inset|children|style|key|ref|className|style|children)$/]",
        "message": "<List> doesn't accept that prop. Declared props: header, footer, inset, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|iconColor|iconTile|value|accessory|selected|trailing|last|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: title, subtitle, icon, iconColor, iconTile, value, accessory, selected, trailing, last, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|destructive|separator|key|ref|className|style|children)$/]",
        "message": "<MenuItem> doesn't accept that prop. Declared props: label, value, icon, destructive, separator."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavigationBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|largeTitle|back|onBack|leading|trailing|translucent|style|key|ref|className|style|children)$/]",
        "message": "<NavigationBar> doesn't accept that prop. Declared props: title, largeTitle, back, onBack, leading, trailing, translucent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NotificationBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:appIcon|appName|time|title|body|style|key|ref|className|style|children)$/]",
        "message": "<NotificationBanner> doesn't accept that prop. Declared props: appIcon, appName, time, title, body, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|index|tint|style|key|ref|className|style|children)$/]",
        "message": "<PageControl> doesn't accept that prop. Declared props: count, index, tint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tint|track|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tint, track, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: value, defaultValue, placeholder, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:segments|value|defaultValue|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: segments, value, defaultValue, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|grabber|detent|radius|style|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: children, grabber, detent, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|tint|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, min, max, onChange, tint, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|dark|battery|style|key|ref|className|style|children)$/]",
        "message": "<StatusBar> doesn't accept that prop. Declared props: time, dark, battery, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, min, max, step, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|tint|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, tint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tab'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|iconSelected|key|ref|className|style|children)$/]",
        "message": "<Tab> doesn't accept that prop. Declared props: value, label, icon, iconSelected."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|variant|icon|clearable|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: value, defaultValue, placeholder, variant, icon, clearable, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|bordered)$/]",
        "message": "<TextField> variant must be one of 'filled' | 'bordered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toolbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|position|translucent|justify|style|key|ref|className|style|children)$/]",
        "message": "<Toolbar> doesn't accept that prop. Declared props: children, position, translucent, justify, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toolbar'] > JSXAttribute[name.name='position'] > Literal[value!=/^(?:top|bottom)$/]",
        "message": "<Toolbar> position must be one of 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Widget'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|children|background|padding|style|key|ref|className|style|children)$/]",
        "message": "<Widget> doesn't accept that prop. Declared props: size, children, background, padding, style."
