      {
        "selector": "JSXOpeningElement[name.name='Widget'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Widget> size must be one of 'small' | 'medium' | 'large'."
      }
